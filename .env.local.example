# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: service role (CLI CSV ingest, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: Google service account JSON (single line) — Drive read-only export for Admin “Backfill full_text from Google”
# Create in GCP → IAM → Service Accounts → Keys → JSON. Share each Doc (or a parent folder) with the account’s client_email.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}

# Optional: OpenAI for embeddings / hybrid search / Ask
# OPENAI_API_KEY=sk-...

# Optional: canonical site URL for Open Graph, Twitter cards, and canonical links (include https, no trailing slash)
# Production example: https://searchtheword.vercel.app
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
